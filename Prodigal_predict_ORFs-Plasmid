# Create an output directory to store all Prodigal results for plasmids
# (-p is safe here; mkdir -p avoids errors if it already exists)
mkdir -p prodigal_out-plasmids

# Loop over every FASTA file in the plasmids directory
# Each file is treated as an independent plasmid genome
for f in plasmids/*.fasta; do

    # Extract just the filename without path and remove ".fasta" extension
    # Example: plasmids/plasmid1.fasta → plasmid1
    base=$(basename "$f" .fasta)

    # Run Prodigal gene prediction on the current plasmid
    prodigal \

        -i "$f" \   # Input FASTA file (current plasmid sequence)

        -o prodigal_out-plasmids/${base}.gff \   # Output gene annotations (GFF format)
                                                  # Contains gene coordinates, strands, scores

        -a prodigal_out-plasmids/${base}.faa \   # Output predicted proteins (amino acid sequences)
                                                  # Useful for BLAST, functional annotation, RT detection

        -d prodigal_out-plasmids/${base}.fna \   # Output predicted coding DNA sequences (nucleotide CDS)
                                                  # Useful for phylogenetics and codon-based analyses

        -p meta \   # Metagenomic mode: uses a general gene model instead of training per genome
                    # Important for small plasmids where training is unreliable

        -g 4        # Genetic code table 4 (Mycoplasma/Spiroplasma code)
                    # UGA is translated as Tryptophan instead of STOP

done
